DATABASE_URL="file:./dev.db"
JWT_SECRET="cambia-esto-en-produccion"
PORT=3010
CHALLENGE_DATE=2026-08-29T20:00:00-04:00

WEBAUTHN_RP_NAME=Reto
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3011

# Web Push (generar con: npm run vapid:generate)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_MAILTO=mailto:admin@los4.local

ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@los4.local
ADMIN_PASSWORD=Admin123!

# URL pública del frontend (links en WhatsApp e invitaciones)
APP_PUBLIC_URL=http://localhost:3011
FRONTEND_URL=http://localhost:3011

# Passkeys — lista de orígenes permitidos (prod, preview, local)
# WEBAUTHN_ORIGINS=https://tu-app.vercel.app,https://tu-app-*.vercel.app,http://localhost:3011

# WhatsApp Baileys (mismo sistema que Musikales Pro)
WHATSAPP_AUTH_FOLDER=/data/whatsapp-auth
# WHATSAPP_DB_PERSIST=0
# WHATSAPP_AUTO_CONNECT_ON_BOOT=0
# WHATSAPP_BOOT_CONNECT_DELAY_MS=8000
# Por defecto se usa fetchLatestBaileysVersion (evita 405). Fija o desactiva:
# WHATSAPP_WA_VERSION=2,3000,1035194821
# WHATSAPP_USE_LATEST_WA_VERSION=0

# Producción Koyeb — volumen los4-data-fra montado en /data:
#   /data/los4.db          → usuarios, WhatsAppAuthArchive, mensajes
#   /data/uploads          → fotos de perfil
#   /data/whatsapp-auth      → credenciales Baileys (copia también en BD)
