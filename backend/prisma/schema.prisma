generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(cuid())
  username          String   @unique
  email             String   @unique
  passwordHash      String
  role              String   @default("PLAYER")
  isActive          Boolean  @default(true)
  passkeyRegistered Boolean  @default(false)

  displayName String
  nickname    String?
  gender      String  @default("OTHER")
  avatarEmoji String  @default("😎")
  avatarUrl   String?
  bio         String?
  bgMode      String  @default("beach")
  bgUrl       String?
  phone       String?
  whatsappOptIn Boolean @default(false)
  pushOptIn   Boolean  @default(false)
  setupCompletedAt DateTime?
  invitedById String?
  invitedBy   User?   @relation("UserInvites", fields: [invitedById], references: [id], onDelete: SetNull)
  invitees    User[]  @relation("UserInvites")

  points     Int       @default(0)
  lastContinuedAt DateTime?
  clemencyUsedAt  DateTime?
  bribeAcceptedCycle Int?

  passkeys         Passkey[]
  actions          GameAction[]
  pushSubscriptions PushSubscription[]
  confessions      Confession[]
  chatMessages     ChatMessage[]
  invitesSent      Invite[]     @relation("InvitesSent")
  votesCast        Vote[]       @relation("VotesCast")
  votesReceived    Vote[]       @relation("VotesReceived")
  alliances        Alliance[]   @relation("AllianceUser")
  partnerAlliances Alliance[]   @relation("AlliancePartner")
  chestClaims      ChestClaim[]
  radioTracks      CommunityRadioTrack[]
  stories          Story[]
  storyViews       StoryView[]
  storyReactions   StoryReaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model Invite {
  id        String    @id @default(cuid())
  code      String    @unique
  inviterId String
  inviter   User      @relation("InvitesSent", fields: [inviterId], references: [id], onDelete: Cascade)
  guestName String?
  usedById  String?
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([code])
  @@index([inviterId, usedAt])
}

model WebAuthnChallenge {
  id        String   @id @default(cuid())
  challenge String   @unique
  userId    String?
  type      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([challenge])
}

model Passkey {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId String    @unique
  publicKey    String
  counter      BigInt    @default(0)
  deviceName   String?
  isActive     Boolean   @default(true)
  lastUsed     DateTime?
  createdAt    DateTime  @default(now())
}

model GameAction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  pointsDelta Int      @default(0)
  metadata    String?
  isAnonymous Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([userId, type, createdAt])
}

model AppConfig {
  id    String @id @default("main")
  key   String @unique
  value String
}

model Redemption {
  id        String   @id @default(cuid())
  userId    String
  rewardId  String
  cost      Int
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /** Único por dispositivo/navegador — un usuario puede tener varias */
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Confession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  revealed  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Vote {
  id         String   @id @default(cuid())
  voterId    String
  voter      User     @relation("VotesCast", fields: [voterId], references: [id], onDelete: Cascade)
  targetId   String
  target     User     @relation("VotesReceived", fields: [targetId], references: [id], onDelete: Cascade)
  cycleIndex Int
  voteType   String
  createdAt  DateTime @default(now())

  @@unique([voterId, cycleIndex, voteType])
}

model Alliance {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation("AllianceUser", fields: [userId], references: [id], onDelete: Cascade)
  partnerId  String
  partner    User     @relation("AlliancePartner", fields: [partnerId], references: [id], onDelete: Cascade)
  cycleIndex Int
  createdAt  DateTime @default(now())

  @@unique([userId, cycleIndex])
}

model ChestClaim {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycleIndex Int
  clue       String
  createdAt  DateTime @default(now())

  @@unique([userId, cycleIndex])
}

model WhatsAppSession {
  id            String    @id @default(cuid())
  sessionId     String    @unique @default("main")
  isConnected   Boolean   @default(false)
  phoneNumber   String?
  lastConnected DateTime?
  qrCode        String?
  qrExpiry      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model WhatsAppTemplate {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @unique
  subject   String
  content   String
  variables String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WhatsAppMessage {
  id           String    @id @default(cuid())
  phoneNumber  String
  templateCode String?
  message      String
  status       String    @default("PENDING")
  errorMessage String?
  messageId    String?
  sentAt       DateTime?
  createdAt    DateTime  @default(now())
}

model WhatsAppAuthArchive {
  id        String   @id @default("main")
  data      Bytes
  updatedAt DateTime @updatedAt
}

model CommunityRadioTrack {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  sourceType  String
  sourceRef   String?
  audioFile   String
  audioUrl    String
  durationSec Int?
  fileSizeKb  Int?
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([isActive, createdAt])
  @@index([userId, createdAt])
}

model Story {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaUrl  String
  caption   String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  views     StoryView[]
  reactions StoryReaction[]

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model StoryReaction {
  id        String   @id @default(cuid())
  storyId   String
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emoji     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storyId, userId])
  @@index([storyId])
}

model StoryView {
  id       String   @id @default(cuid())
  storyId  String
  story    Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  viewerId String
  viewer   User     @relation(fields: [viewerId], references: [id], onDelete: Cascade)
  viewedAt DateTime @default(now())

  @@unique([storyId, viewerId])
  @@index([viewerId])
}
