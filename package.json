{
  "name": "los4",
  "version": "1.0.0",
  "description": "Reto PWA",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "concurrently \"pnpm run dev:backend\" \"pnpm run dev:frontend\"",
    "dev:backend": "pnpm -C backend dev",
    "dev:frontend": "pnpm -C frontend dev",
    "build": "pnpm run build:backend && pnpm run build:frontend",
    "build:backend": "pnpm -C backend build",
    "build:frontend": "pnpm -C frontend build",
    "db:push": "pnpm -C backend exec prisma db push",
    "db:seed": "pnpm -C backend db:seed",
    "install:all": "pnpm install"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
